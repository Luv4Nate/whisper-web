PORT=3000
FRONTEND_ORIGIN=http://localhost:3000
# Public site URL (no trailing slash). Used in receipts and signed download links.
PUBLIC_SITE_URL=http://localhost:3000
STRIPE_SECRET_KEY=sk_test_YOUR_TEST_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
SUCCESS_URL=http://localhost:3000/?payment=success
CANCEL_URL=http://localhost:3000/?payment=cancel
# Optional: direct HTTPS URL to your launcher if you do not use LAUNCHER_PATH on this server.
DOWNLOAD_LINK=https://yourdomain.com/whisper-launcher
# After building Release|x64, path to whisper.cc.exe on the machine that runs this server.
LAUNCHER_PATH=C:\\Users\\nate\\Desktop\\whisper\\release\\whisper.cc.exe
# Required when LAUNCHER_PATH is set: long random string for short-lived download tokens.
DOWNLOAD_TOKEN_SECRET=super-secret-download-token
# Discord bot configuration for license verification and launcher delivery.
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN
DISCORD_CLIENT_ID=YOUR_DISCORD_CLIENT_ID
DISCORD_GUILD_ID=YOUR_DISCORD_GUILD_ID
# Set to true only for debugging — launcher will not bind a machine HWID to a license.
DISABLE_HWID_LOCK=

# --- Receipt email (required for customers to get license by mail after Stripe webhook) ---
# Gmail: host smtp.gmail.com, port 587, user your@gmail.com, pass = 16-char App Password (not your login password).
# Outlook: smtp-mail.outlook.com, port 587.
# SendGrid: host smtp.sendgrid.net, port 587, user apikey, pass = your SendGrid API key.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
# Use true + port 465 for some providers (implicit TLS).
EMAIL_SECURE=false
EMAIL_USER=you@gmail.com
EMAIL_PASS=your_app_password_here
RECEIPT_FROM=Whisper <you@gmail.com>
RECEIPT_REPLY_TO=you@gmail.com
