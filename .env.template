PORT=3000

# Railway deployment domain (example: whisper-app-1234.up.railway.app)
FRONTEND_ORIGIN=https://YOUR_RAILWAY_URL_HERE
PUBLIC_SITE_URL=https://YOUR_RAILWAY_URL_HERE
SUCCESS_URL=https://YOUR_RAILWAY_URL_HERE/?payment=success
CANCEL_URL=https://YOUR_RAILWAY_URL_HERE/?payment=cancel

# Stripe payment processing
# Get from: https://stripe.com → Settings → API Keys → Secret Key
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_HERE

# Stripe webhook signing
# Get from: https://stripe.com → Webhooks → (click your webhook) → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET_HERE

# Launcher download protection
# Generate a random 32+ character string using: https://www.random.org/strings/
DOWNLOAD_TOKEN_SECRET=your-super-secret-random-string-minimum-32-characters-long

# Local launcher file (relative path in Railway)
LAUNCHER_PATH=./release/whisper.cc.exe

# Set to false for production (enables HWID machine binding)
DISABLE_HWID_LOCK=false

# Email service (Brevo - free tier)
# Get SMTP password from: https://brevo.com → SMTP & API
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@domain.com
EMAIL_PASS=your-brevo-smtp-password-here

# Verified sender email in SendGrid
# Must match a verified sender in: https://sendgrid.com → Sender Authentication
RECEIPT_FROM=Whisper <noreply@whisper.cc>
RECEIPT_REPLY_TO=support@youremail.com

# Discord bot for license verification
# Get token from: https://discord.com/developers/applications → Bot → TOKEN
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# Get IDs from Discord with Developer Mode enabled
# Guild ID: Right-click server → Copy Server ID
DISCORD_GUILD_ID=YOUR_DISCORD_GUILD_ID_HERE

# Client ID: Right-click bot in members → Copy User ID
DISCORD_CLIENT_ID=YOUR_DISCORD_CLIENT_ID_HERE
